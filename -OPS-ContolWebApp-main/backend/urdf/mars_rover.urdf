<?xml version="1.0"?>
<!--
  Mars Rover URDF — 6-DOF manipulator + 4 crab-drive wheels
  ==========================================================

  Kinematic layout:
    base_link
      ├── steer_{FL,FR,RL,RR}_link  (revolute yaw — Z-axis)
      │     └── wheel_{FL,FR,RL,RR}  (continuous spin — Y-axis)
      └── arm_base_link  (revolute yaw — Z-axis)
            └── arm_shoulder_link → arm_elbow_link → wrist → gripper

  Each wheel has two DOFs:
    1. steer_*_joint  — revolute ±90° for independent yaw steering (crab drive)
    2. wheel_*_joint  — continuous spin for drive

  Manipulator: 6-DOF (base yaw, shoulder pitch, elbow pitch,
               wrist pitch, wrist roll, prismatic gripper)
-->
<robot name="mars_rover">

  <!-- ========== MATERIALS ========== -->
  <material name="chassis_material">
    <color rgba="0.2 0.2 0.3 1.0"/>
  </material>

  <material name="wheel_material">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>

  <material name="steer_material">
    <color rgba="0.3 0.3 0.4 1.0"/>
  </material>

  <material name="arm_base">
    <color rgba="0.9 0.3 0.2 1.0"/>
  </material>

  <material name="arm_link">
    <color rgba="0.9 0.6 0.1 1.0"/>
  </material>

  <material name="gripper_material">
    <color rgba="0.2 0.8 0.4 1.0"/>
  </material>

  <!-- ========== BASE LINK (Chassis) ========== -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry>
        <box size="0.6 0.4 0.15"/>
      </geometry>
      <material name="chassis_material"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry>
        <box size="0.6 0.4 0.15"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="5.0"/>
      <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
    </inertial>
  </link>

  <!-- ========== CRAB-DRIVE WHEELS ========== -->
  <!-- Each wheel has: steering link (yaw) → wheel link (spin) -->

  <!-- ===== Front Left ===== -->
  <link name="steer_front_left_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.04"/>
      </geometry>
      <material name="steer_material"/>
    </visual>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="steer_front_left" type="revolute">
    <parent link="base_link"/>
    <child link="steer_front_left_link"/>
    <origin xyz="0.25 0.25 0.08" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.5708" upper="1.5708" effort="5.0" velocity="1.5"/>
  </joint>

  <link name="wheel_front_left">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.08" length="0.06"/>
      </geometry>
      <material name="wheel_material"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.08" length="0.06"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
  </link>

  <joint name="wheel_front_left_joint" type="continuous">
    <parent link="steer_front_left_link"/>
    <child link="wheel_front_left"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ===== Front Right ===== -->
  <link name="steer_front_right_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.04"/>
      </geometry>
      <material name="steer_material"/>
    </visual>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="steer_front_right" type="revolute">
    <parent link="base_link"/>
    <child link="steer_front_right_link"/>
    <origin xyz="0.25 -0.25 0.08" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.5708" upper="1.5708" effort="5.0" velocity="1.5"/>
  </joint>

  <link name="wheel_front_right">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.08" length="0.06"/>
      </geometry>
      <material name="wheel_material"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.08" length="0.06"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
  </link>

  <joint name="wheel_front_right_joint" type="continuous">
    <parent link="steer_front_right_link"/>
    <child link="wheel_front_right"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ===== Rear Left ===== -->
  <link name="steer_rear_left_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.04"/>
      </geometry>
      <material name="steer_material"/>
    </visual>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="steer_rear_left" type="revolute">
    <parent link="base_link"/>
    <child link="steer_rear_left_link"/>
    <origin xyz="-0.25 0.25 0.08" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.5708" upper="1.5708" effort="5.0" velocity="1.5"/>
  </joint>

  <link name="wheel_rear_left">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.08" length="0.06"/>
      </geometry>
      <material name="wheel_material"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.08" length="0.06"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
  </link>

  <joint name="wheel_rear_left_joint" type="continuous">
    <parent link="steer_rear_left_link"/>
    <child link="wheel_rear_left"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ===== Rear Right ===== -->
  <link name="steer_rear_right_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.04"/>
      </geometry>
      <material name="steer_material"/>
    </visual>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="steer_rear_right" type="revolute">
    <parent link="base_link"/>
    <child link="steer_rear_right_link"/>
    <origin xyz="-0.25 -0.25 0.08" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.5708" upper="1.5708" effort="5.0" velocity="1.5"/>
  </joint>

  <link name="wheel_rear_right">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.08" length="0.06"/>
      </geometry>
      <material name="wheel_material"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.08" length="0.06"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
  </link>

  <joint name="wheel_rear_right_joint" type="continuous">
    <parent link="steer_rear_right_link"/>
    <child link="wheel_rear_right"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ========== 6-DOF MANIPULATOR ARM ========== -->

  <!-- Manipulator Base (Revolute - Yaw) -->
  <link name="arm_base_link">
    <visual>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.08" length="0.1"/>
      </geometry>
      <material name="arm_base"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.08" length="0.1"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
  </link>

  <joint name="joint_base" type="revolute">
    <parent link="base_link"/>
    <child link="arm_base_link"/>
    <origin xyz="0 0 0.23" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" effort="10.0" velocity="1.0"/>
  </joint>

  <!-- Shoulder Link (Revolute - Pitch) -->
  <link name="arm_shoulder_link">
    <visual>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.06 0.3"/>
      </geometry>
      <material name="arm_link"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.06 0.3"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.8"/>
      <inertia ixx="0.008" ixy="0.0" ixz="0.0" iyy="0.008" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="joint_shoulder" type="revolute">
    <parent link="arm_base_link"/>
    <child link="arm_shoulder_link"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="8.0" velocity="1.0"/>
  </joint>

  <!-- Elbow Link (Revolute - Pitch) -->
  <link name="arm_elbow_link">
    <visual>
      <origin xyz="0 0 0.12" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.24"/>
      </geometry>
      <material name="arm_link"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.12" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.24"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.6"/>
      <inertia ixx="0.005" ixy="0.0" ixz="0.0" iyy="0.005" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="joint_elbow" type="revolute">
    <parent link="arm_shoulder_link"/>
    <child link="arm_elbow_link"/>
    <origin xyz="0 0 0.3" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.0" upper="2.0" effort="6.0" velocity="1.0"/>
  </joint>

  <!-- Wrist Pitch Link -->
  <link name="arm_wrist_pitch_link">
    <visual>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.03" length="0.1"/>
      </geometry>
      <material name="arm_link"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.03" length="0.1"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="joint_wrist_pitch" type="revolute">
    <parent link="arm_elbow_link"/>
    <child link="arm_wrist_pitch_link"/>
    <origin xyz="0 0 0.24" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="4.0" velocity="1.0"/>
  </joint>

  <!-- Wrist Roll Link -->
  <link name="arm_wrist_roll_link">
    <visual>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <geometry>
        <box size="0.08 0.04 0.06"/>
      </geometry>
      <material name="gripper_material"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <geometry>
        <box size="0.08 0.04 0.06"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="joint_wrist_roll" type="revolute">
    <parent link="arm_wrist_pitch_link"/>
    <child link="arm_wrist_roll_link"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-3.14159" upper="3.14159" effort="2.0" velocity="1.0"/>
  </joint>

  <!-- Gripper Left Finger -->
  <link name="gripper_left_finger">
    <visual>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <geometry>
        <box size="0.015 0.025 0.08"/>
      </geometry>
      <material name="gripper_material"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <geometry>
        <box size="0.015 0.025 0.08"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="joint_gripper" type="prismatic">
    <parent link="arm_wrist_roll_link"/>
    <child link="gripper_left_finger"/>
    <origin xyz="-0.02 0 0.06" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="0.0" upper="0.04" effort="5.0" velocity="0.5"/>
  </joint>

  <!-- Gripper Right Finger (mimic left) -->
  <link name="gripper_right_finger">
    <visual>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <geometry>
        <box size="0.015 0.025 0.08"/>
      </geometry>
      <material name="gripper_material"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <geometry>
        <box size="0.015 0.025 0.08"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="joint_gripper_mirror" type="fixed">
    <parent link="arm_wrist_roll_link"/>
    <child link="gripper_right_finger"/>
    <origin xyz="0.02 0 0.06" rpy="0 0 0"/>
  </joint>

  <!-- End Effector Frame -->
  <link name="end_effector">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.01"/>
      </geometry>
      <material name="gripper_material"/>
    </visual>
  </link>

  <joint name="end_effector_joint" type="fixed">
    <parent link="arm_wrist_roll_link"/>
    <child link="end_effector"/>
    <origin xyz="0 0 0.14" rpy="0 0 0"/>
  </joint>

</robot>
