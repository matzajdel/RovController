# OPS Control WebApp - Configuration File
# Edit this file to switch between development and production environments

# Environment: "development" or "production"
ENVIRONMENT=development

# Backend Configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=2137

# Development URLs (localhost)
DEV_BACKEND_IP=192.168.1.118
DEV_FRONTEND_IP=192.168.1.118
DEV_FRONTEND_PORT=3000

# Production URLs (actual deployment)
PROD_BACKEND_IP=192.168.2.100
PROD_FRONTEND_IP=192.168.2.100
PROD_FRONTEND_PORT=3000

# ROS 2 Configuration
ROS_DOMAIN_ID=0
ROS_LOCALHOST_ONLY=0

# Logging
LOG_LEVEL=info

# Robot Control Settings
MAX_LINEAR_SPEED=1.0
MAX_ANGULAR_SPEED=1.0
COMMAND_TIMEOUT=0.5

